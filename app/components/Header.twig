<!DOCTYPE html>
<html
  lang="fr"
  x-data="{
    theme: getTheme(),
    toggleTheme() {
      const newTheme = toggleStorageTheme();
      this.theme = newTheme;
    }
  }"
>

<head>
<meta charset="utf-8">
<meta charset="UTF-8" />
<link rel="stylesheet" href="app/css/style.css" />
<title>Blog - {{ title }}</title>
<!-- Chargement de Bootstrap 5 -->
<link href="app/css/bootstrap.min.css" rel="stylesheet">
<!-- Définition de la taille de l'écran pour l'affichage mobile -->
<meta name="viewport" content="width=device-width, initial-scale=1">
</head>


<body x-bind:class="theme">
  <!-- Barre de navigation -->
  <nav >
    <nav class="navbar navbar-expand-lg "
       :class="theme === 'dark' ? 'navbar-dark navbar-custom-dark' : 'navbar-light navbar-custom-light'">
      <div class="container" >
        <!-- Logo ou nom du site -->
        <a class="navbar-brand" href="#">BLOG</a>
        <!-- Bouton de bascule pour les petits écrans -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-
        controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
        </button>
        <!-- Contenu de la barre de navigation -->
        <div class="collapse navbar-collapse" id="navbarNav">
          <!-- Liste des éléments de navigation -->

          <ul class="navbar-nav">
          <!-- Élément de navigation actif -->
          <li class="nav-item active">
          <a class="nav-link" href="/" aria-current="{{ path == "/" ? "true" : "false" }}"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-house" viewBox="0 0 16 16">
          <path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293zM13 7.207V13.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V7.207l5-5z"/>
          </svg> Accueil <span class="visually-hidden">(current)</span></a>
          </li>

          <!-- Autres éléments de navigation -->
          <li class="nav-item">
          <a class="nav-link" href="/signin" aria-current="{{ path == "/signin" ? "true" : "false" }}"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-check" viewBox="0 0 16 16">
          <path d="M12.5 16a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7m1.679-4.493-1.335 2.226a.75.75 0 0 1-1.174.144l-.774-.773a.5.5 0 0 1 .708-.708l.547.548 1.17-1.951a.5.5 0 1 1 .858.514M11 5a3 3 0 1 1-6 0 3 3 0 0 1 6 0M8 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4"/>
          <path d="M8.256 14a4.5 4.5 0 0 1-.229-1.004H3c.001-.246.154-.986.832-1.664C4.484 10.68 5.711 10 8 10q.39 0 .74.025c.226-.341.496-.65.804-.918Q8.844 9.002 8 9c-5 0-6 3-6 4s1 1 1 1z"/>
          </svg> Connexion</a>
          </li>

          <li class="nav-item">
          
          <a class="nav-link" href="/register" aria-current="{{ path == "/register" ? "true" : "false" }}"  ><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-fill-add" viewBox="0 0 16 16">
          <path d="M12.5 16a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7m.5-5v1h1a.5.5 0 0 1 0 1h-1v1a.5.5 0 0 1-1 0v-1h-1a.5.5 0 0 1 0-1h1v-1a.5.5 0 0 1 1 0m-2-6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
          <path d="M2 13c0 1 1 1 1 1h5.256A4.5 4.5 0 0 1 8 12.5a4.5 4.5 0 0 1 1.544-3.393Q8.844 9.002 8 9c-5 0-6 3-6 4"/>
          </svg> Inscription</a>
          </li>

          </ul>
        </div>
    </nav>
    
      <div class="theme-toggle-container">
              <span>Sombre</span>
              <input type="checkbox" id="theme-toggle" x-on:change="toggleTheme()" />
              <label
                class="theme-toggle"
                for="theme-toggle"
                x-bind:aria-checked="theme === 'dark' ? true : false"
              >
                <span></span>
              </label>
            </div>
      </div>
  </nav>

