<h1>{{ pages['tags'] }}</h1>

<form action="/dashboard?view=tags" method="POST">
  <h3>Créer un tag</h3>
  <div class="form-group" style="max-width: 350px;">
    <label for="new_tag_name">Nom du tag</label>
    <input type="text" id="new_tag_name" name="new_tag_name" placeholder="Nom du tag" class="form-control" />
    <button type="submit" name="tags:create" class="btn btn-primary">Créer un tag</button>
  </div>
</form>

<span class="separator"></span>

<form action="/dashboard?view=tags" method="POST">
  <table class="table">
    <thead>
      <tr>
        <th scope="col">#</th>
        <th scope="col">Nom</th>
        <th scope="col">Slug</th>
        <th scope="col">Articles associés</th>
        <th scope="col">Actions</th>
      </tr>
    </thead>

    <tbody>
      {% for tag in data.tags %}
      <tr>
        <th scope="row">{{tag.id}}</th>
        <td>{{tag.nom_tag}}</td>
        <td>{{tag.slug}}</td>
        <td>{{tag.nb_articles}}</td>
        <td>
          <button name="tags:delete" value="{{ tag.id }}" class="btn btn-danger" title="Supprimer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
              <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
              <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
            </svg>
          </button>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</form>

