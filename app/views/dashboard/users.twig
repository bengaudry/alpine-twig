<h1>{{ pages['users'] }}</h1>

<form action="" method="POST">

<table class="table">
    <thead>
    <tr>
        <th scope="col">#</th>
        <th scope="col">Nom d'utilisateur</th>
        <th scope="col">Email</th>
        <th scope="col">Date inscription</th>
        <th scope="col">Rôles</th>
        <th scope="col">Actions</th>
    </tr>
    </thead>
    <tbody>
    {% for user in data['users'] %}
        <tr>
                <input type="hidden" name="users:user-id" value="{{ user.id }}">
                <th scope="row">{{ user.id }}</th>
                <td>{{ user.nom_utilisateur }}</td>
                <td>{{ user.email }}</td>
                <td>{{ user.date_inscription }}</td>
                <td class="d-flex flex-column">
                    {% for role in data['roles'] %}
                        <div class="form-check">
                            <input type="checkbox" name="users:toggle-role_roleid" value="{{ role.id }}"
                                   onchange="this.form.submit()" {{ role.nom_role in user.roles ? "checked" }}
                                    class="form-check-input"
                            />
                            <label class="form-check-label">{{ role.nom_role }}</label>
                        </div>
                    {% endfor %}
                </td>
                <td>
                    <button name="users:toggle-activation" value="{{ user.id }}"
                            class="btn {{ user.est_actif == 1 ? 'btn-danger'
                            : 'btn-success' }}"
                    >
                        {{ user.est_actif ? 'Désactiver' : 'Activer' }}
                    </button>
                </td>
        </tr>
    {% endfor %}
    </tbody>
</table>

</form>
